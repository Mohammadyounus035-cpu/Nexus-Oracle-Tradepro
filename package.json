{
  "name": "work-monorepo",
  "version": "1.0.0",
  "description": "Monorepo for Omega Lattice and Nexus Core projects.",
  "private": true,
  "scripts": {
    "install:all": "pnpm install",
    "build:all": "pnpm -r build",
    "test:all": "pnpm -r test",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "ingest": "ts-node ingest.ts",
    "ingest:watch": "ts-node-dev --respawn ingest.ts"
  },
  "keywords": [],
  "author": "Manus AI",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*",
    "nexus-core",
    "allocator-service"
  ],
  "devDependencies": {
    "databento": "^0.32.3",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
